generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  password   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  notes      Note[]
  favorites  Favorite[]
}

model Note {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  content     String?
  fileUrl     String
  course      String
  category    String?
  views       Int        @default(0)
  likes       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  authorId    Int
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags        NoteTag[]
  favorites   Favorite[]

  @@index([course])
  @@index([category])
  @@index([createdAt])
}

model Tag {
  id          Int        @id @default(autoincrement())
  name        String     @unique

  notes       NoteTag[]
}

model NoteTag {
  noteId      Int
  tagId       Int

  note        Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag         Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

model Favorite {
  id          Int        @id @default(autoincrement())
  userId      Int
  noteId      Int
  createdAt   DateTime   @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  note        Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId])
}
